{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "bun *": "allow",
          "cargo *": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "mkdir *": "allow",
          "move *": "allow",
          "pyrefly *": "allow",
          "ruff *": "allow"
        },
        "edit": "allow"
      }
    }
  },
  "autoupdate": false,
  "lsp": false,
  "permission": {
    "bash": {
      "*": "ask",
      "cat": "allow",
      "cut": "allow",
      "echo": "allow",
      "find *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "yq *": "allow"
    },
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "share": "disabled"
}
