{
  "cli_default_open_behavior": "new_window",
  "buffer_line_height": "comfortable",
  "buffer_font_size": 16.0,
  "proxy": "",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "colorize_brackets": true,
  "language_models": {
    "openai_compatible": {},
  },
  "double_click_in_multibuffer": "select",
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "never",
  },
  "edit_predictions": {
    "provider": "zed",
    "copilot": {
      "enable_next_edit_suggestions": false,
    },
    "mode": "subtle",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "window_decorations": "server",
  "auto_install_extensions": {
    "git-firefly": true,
    "html": true,
    "lua": true,
    "nix": true,
    "toml": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "autoscroll_on_clicks": true,
  "buffer_font_family": ".ZedMono",
  "show_signature_help_after_edits": true,
  "auto_update": false,
  "confirm_quit": true,
  "edit_predictions_disabled_in": ["comment", "string"],
  "scrollbar": {
    "axes": {
      "horizontal": false,
    },
  },
  "languages": {
    "Nix": {
      "language_servers": ["!nil", "nixd"],
    },
    "Python": {
      "language_servers": ["zuban", "!basedpyright"],
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
          "extraArgs": [
            "--",
            "-W",
            "clippy::pedantic",
            "-W",
            "clippy::nursery",
          ],
        },
        "checkOnSave": false,
        "diagnostics": { "experimental": { "enable": true } },
        "inlayHints": {
          "closingBraceHints": { "minLines": 8 },
          "closureReturnTypeHints": { "enable": "with_block" },
          "discriminantHints": { "enable": "fieldless" },
          "lifetimeElisionHints": { "enable": "skip_trivial" },
        },
        "rustfmt": {
          "extraArgs": ["--unstable-features"],
          "rangeFormatting": { "enable": true },
        },
      },
    },
  },
  "format_on_save": "on",
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "journal": {
    "hour_format": "hour24",
  },
  "relative_line_numbers": "enabled",
  "restore_on_startup": "empty_tab",
  "use_smartcase_search": true,
  "soft_wrap": "editor_width",
  "wrap_guides": [80, 100, 120],
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_family": "Fira Code",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "vim_mode": true,
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "inline_assistant_model": {
      "provider": "MiniMax",
      "model": "MiniMax-M2.5",
    },
    "enabled": true,
    "default_profile": "ask",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "gpt-5.4",
    },
  },
  "ui_font_family": ".ZedMono",
}
